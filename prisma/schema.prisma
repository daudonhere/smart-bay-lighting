generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Bay {
  id        String    @id
  relayPin  Int       @default(0)
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Booking {
  id           String   @id @default(cuid())
  bayId        String
  customerName String
  startTime    DateTime
  endTime      DateTime
  status       String   @default("created") // created, started, extended, ended, cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bayId])
  @@index([status])
  @@index([startTime])
}
